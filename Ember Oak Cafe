<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Ember & Oak — Café</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=Lora:ital,wght@0,400;0,500;1,400&family=Jost:wght@200;300;400&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --espresso:  #140a04;
      --mahogany:  #2b1206;
      --amber:     #c47a28;
      --amber-lt:  #e09848;
      --cream:     #f4ead8;
      --parchment: #ede0c4;
      --latte:     #c9a46e;
      --rust:      #7a3318;
      --smoke:     #8a7060;
      --warm-white:#fdf8f0;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--espresso);
      color: var(--cream);
      font-family: 'Lora', serif;
      overflow-x: hidden;
      cursor: none;
    }

    /* ── CUSTOM CURSOR ── */
    .cursor {
      width: 10px; height: 10px; border-radius: 50%;
      background: var(--amber); position: fixed;
      pointer-events: none; z-index: 99999;
      transform: translate(-50%, -50%);
      transition: transform 0.1s, width 0.3s, height 0.3s, background 0.3s;
      mix-blend-mode: normal;
    }
    .cursor-ring {
      width: 36px; height: 36px; border-radius: 50%;
      border: 1px solid rgba(196,122,40,0.5);
      position: fixed; pointer-events: none; z-index: 99998;
      transform: translate(-50%, -50%);
      transition: transform 0.18s ease, width 0.3s, height 0.3s;
    }
    body:hover .cursor { opacity: 1; }

    /* ── LOADER ── */
    #loader {
      position: fixed; inset: 0; z-index: 10000;
      background: var(--espresso);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      transition: opacity 0.8s ease, visibility 0.8s;
    }
    #loader.done { opacity: 0; visibility: hidden; }

    .loader-cup {
      width: 80px; height: 80px; margin-bottom: 36px;
      position: relative;
      animation: cup-bob 2s ease-in-out infinite;
    }
    @keyframes cup-bob { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }

    .loader-cup svg { width: 100%; height: 100%; }
    .cup-fill { animation: fill-up 2.4s ease forwards; }
    @keyframes fill-up {
      0%   { clip-path: inset(100% 0 0 0); opacity:0 }
      20%  { opacity: 1 }
      100% { clip-path: inset(0% 0 0 0); opacity:1 }
    }
    .steam-line {
      stroke: rgba(196,122,40,0.4); stroke-width: 2;
      fill: none; stroke-linecap: round;
      animation: steam-rise 2s ease-in-out infinite;
    }
    .steam-line:nth-child(2) { animation-delay: 0.3s; }
    .steam-line:nth-child(3) { animation-delay: 0.6s; }
    @keyframes steam-rise { 0%{opacity:0;transform:translateY(0)} 50%{opacity:1} 100%{opacity:0;transform:translateY(-18px)} }

    .loader-brand {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.8rem; font-weight: 300; letter-spacing: 0.25em;
      text-transform: uppercase; color: var(--cream);
      overflow: hidden;
    }
    .loader-brand span {
      display: inline-block;
      animation: letter-drop 0.6s cubic-bezier(.25,.46,.45,.94) both;
    }
    @keyframes letter-drop {
      from { transform: translateY(-40px) rotateX(90deg); opacity:0 }
      to   { transform: translateY(0) rotateX(0deg); opacity:1 }
    }
    .loader-sub {
      font-family: 'Jost', sans-serif; font-weight: 200;
      font-size: 0.65rem; letter-spacing: 0.55em; text-transform: uppercase;
      color: var(--amber); margin-top: 10px;
      animation: fade-in 1s 1.8s both;
    }
    .loader-bar {
      width: 120px; height: 1px; background: var(--mahogany);
      margin-top: 28px; overflow: hidden;
      animation: fade-in 1s 1.5s both;
    }
    .loader-bar-fill {
      height: 100%; background: var(--amber);
      animation: bar-fill 2s 1.5s cubic-bezier(.4,0,.2,1) forwards;
      width: 0;
    }
    @keyframes bar-fill { to { width: 100%; } }
    @keyframes fade-in { from{opacity:0} to{opacity:1} }

    /* ── GRAIN OVERLAY ── */
    .grain {
      position: fixed; inset: 0; z-index: 9000;
      pointer-events: none; opacity: 0.035;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-size: 200px 200px;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 500;
      padding: 20px 60px;
      display: flex; align-items: center; justify-content: space-between;
      transition: background 0.5s, padding 0.4s, backdrop-filter 0.5s;
    }
    nav.scrolled {
      background: rgba(20,10,4,0.92);
      backdrop-filter: blur(12px);
      padding: 14px 60px;
      border-bottom: 1px solid rgba(196,122,40,0.15);
    }
    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem; font-weight: 600; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--cream);
      text-decoration: none;
    }
    .nav-logo span { color: var(--amber); }
    .nav-links { display: flex; gap: 40px; list-style: none; }
    .nav-links a {
      font-family: 'Jost', sans-serif; font-weight: 300;
      font-size: 0.72rem; letter-spacing: 0.3em; text-transform: uppercase;
      color: rgba(244,234,216,0.65); text-decoration: none;
      transition: color 0.3s; position: relative;
    }
    .nav-links a::after {
      content: ''; position: absolute; bottom: -4px; left: 0;
      width: 0; height: 1px; background: var(--amber);
      transition: width 0.3s;
    }
    .nav-links a:hover { color: var(--cream); }
    .nav-links a:hover::after { width: 100%; }

    /* ── HERO ── */
    #hero {
      height: 100vh; position: relative;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: -10%;
      background:
        radial-gradient(ellipse 80% 60% at 60% 40%, rgba(122,51,24,0.35) 0%, transparent 70%),
        radial-gradient(ellipse 50% 40% at 20% 70%, rgba(196,122,40,0.12) 0%, transparent 60%),
        linear-gradient(160deg, #1c0a02 0%, #120804 40%, #0e0604 100%);
      will-change: transform;
    }
    .hero-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(196,122,40,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(196,122,40,0.04) 1px, transparent 1px);
      background-size: 60px 60px;
      will-change: transform;
    }
    .hero-particles {
      position: absolute; inset: 0; pointer-events: none;
      will-change: transform;
    }
    .particle {
      position: absolute; border-radius: 50%;
      background: radial-gradient(circle, rgba(196,122,40,0.4), transparent);
      animation: float-particle linear infinite;
    }
    @keyframes float-particle {
      0%   { transform: translateY(100vh) scale(0); opacity:0 }
      10%  { opacity:1 }
      90%  { opacity:0.3 }
      100% { transform: translateY(-20vh) scale(1); opacity:0 }
    }

    .hero-content {
      position: relative; z-index: 2; text-align: center;
      padding: 0 20px;
      perspective: 800px;
    }
    .hero-eyebrow {
      font-family: 'Jost', sans-serif; font-weight: 200;
      font-size: 0.68rem; letter-spacing: 0.6em; text-transform: uppercase;
      color: var(--amber); margin-bottom: 28px;
      animation: hero-reveal 1s 0.3s both;
    }
    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(4rem, 11vw, 9rem);
      font-weight: 300; line-height: 0.9;
      letter-spacing: -0.01em; color: var(--cream);
      margin-bottom: 32px;
    }
    .hero-title em { font-style: italic; color: var(--amber); }
    .hero-title .line1 { display: block; animation: hero-3d-reveal 1s 0.5s cubic-bezier(.16,1,.3,1) both; }
    .hero-title .line2 { display: block; animation: hero-3d-reveal 1s 0.7s cubic-bezier(.16,1,.3,1) both; }
    @keyframes hero-3d-reveal {
      from { transform: perspective(600px) rotateX(40deg) translateY(60px); opacity:0 }
      to   { transform: perspective(600px) rotateX(0deg) translateY(0); opacity:1 }
    }
    @keyframes hero-reveal {
      from { transform: translateY(20px); opacity:0 }
      to   { transform: translateY(0); opacity:1 }
    }
    .hero-desc {
      font-size: 1.05rem; font-style: italic; color: rgba(244,234,216,0.6);
      max-width: 420px; margin: 0 auto 48px; line-height: 1.8;
      animation: hero-reveal 1s 1s both;
    }
    .hero-cta {
      display: inline-flex; align-items: center; gap: 14px;
      padding: 16px 42px; border: 1px solid var(--amber);
      color: var(--amber); text-decoration: none;
      font-family: 'Jost', sans-serif; font-weight: 300;
      font-size: 0.72rem; letter-spacing: 0.4em; text-transform: uppercase;
      transition: all 0.4s; position: relative; overflow: hidden;
      animation: hero-reveal 1s 1.2s both;
    }
    .hero-cta::before {
      content: ''; position: absolute; inset: 0;
      background: var(--amber); transform: scaleX(0); transform-origin: left;
      transition: transform 0.4s cubic-bezier(.4,0,.2,1);
    }
    .hero-cta:hover { color: var(--espresso); }
    .hero-cta:hover::before { transform: scaleX(1); }
    .hero-cta span { position: relative; z-index: 1; }

    .hero-scroll-hint {
      position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: 8px;
      animation: hero-reveal 1s 1.8s both;
    }
    .scroll-line {
      width: 1px; height: 50px; background: linear-gradient(to bottom, transparent, var(--amber));
      animation: scroll-pulse 2s ease-in-out infinite;
    }
    @keyframes scroll-pulse { 0%,100%{opacity:0.3;transform:scaleY(0.5)} 50%{opacity:1;transform:scaleY(1)} }
    .scroll-text {
      font-family: 'Jost', sans-serif; font-weight: 200;
      font-size: 0.58rem; letter-spacing: 0.4em; text-transform: uppercase;
      color: var(--smoke);
    }

    /* ── SECTION BASE ── */
    section { position: relative; }
    .section-inner { max-width: 1200px; margin: 0 auto; padding: 0 60px; }
    .section-label {
      font-family: 'Jost', sans-serif; font-weight: 200;
      font-size: 0.65rem; letter-spacing: 0.6em; text-transform: uppercase;
      color: var(--amber); display: flex; align-items: center; gap: 20px;
      margin-bottom: 24px;
    }
    .section-label::after { content:''; flex:1; height:1px; background: rgba(196,122,40,0.25); }
    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.4rem, 5vw, 4.2rem);
      font-weight: 300; line-height: 1.1; color: var(--cream);
    }
    .section-title em { font-style: italic; color: var(--amber); }

    /* ── REVEAL ANIMATIONS (triggered by IntersectionObserver) ── */
    .reveal {
      opacity: 0; transform: perspective(800px) rotateX(20deg) translateY(50px);
      transition: opacity 0.9s cubic-bezier(.16,1,.3,1), transform 0.9s cubic-bezier(.16,1,.3,1);
    }
    .reveal.visible { opacity: 1; transform: perspective(800px) rotateX(0deg) translateY(0); }
    .reveal-left {
      opacity: 0; transform: perspective(800px) rotateY(20deg) translateX(-60px);
      transition: opacity 0.9s cubic-bezier(.16,1,.3,1), transform 0.9s cubic-bezier(.16,1,.3,1);
    }
    .reveal-left.visible { opacity: 1; transform: perspective(800px) rotateY(0deg) translateX(0); }
    .reveal-right {
      opacity: 0; transform: perspective(800px) rotateY(-20deg) translateX(60px);
      transition: opacity 0.9s cubic-bezier(.16,1,.3,1), transform 0.9s cubic-bezier(.16,1,.3,1);
    }
    .reveal-right.visible { opacity: 1; transform: perspective(800px) rotateY(0deg) translateX(0); }
    .reveal-scale {
      opacity: 0; transform: scale(0.85) translateY(30px);
      transition: opacity 0.8s cubic-bezier(.16,1,.3,1), transform 0.8s cubic-bezier(.16,1,.3,1);
    }
    .reveal-scale.visible { opacity: 1; transform: scale(1) translateY(0); }
    [data-delay="1"] { transition-delay: 0.1s; }
    [data-delay="2"] { transition-delay: 0.2s; }
    [data-delay="3"] { transition-delay: 0.3s; }
    [data-delay="4"] { transition-delay: 0.4s; }
    [data-delay="5"] { transition-delay: 0.5s; }
    [data-delay="6"] { transition-delay: 0.6s; }

    /* ── MENU SECTION ── */
    #menu {
      padding: 130px 0;
      background: linear-gradient(180deg, var(--espresso) 0%, #1a0d06 50%, var(--espresso) 100%);
    }
    .menu-header { margin-bottom: 80px; }
    .menu-tabs {
      display: flex; gap: 0; margin-top: 40px;
      border-bottom: 1px solid rgba(196,122,40,0.2);
    }
    .menu-tab {
      padding: 14px 32px; background: none; border: none; cursor: none;
      font-family: 'Jost', sans-serif; font-weight: 300;
      font-size: 0.72rem; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--smoke); transition: color 0.3s;
      position: relative;
    }
    .menu-tab::after {
      content: ''; position: absolute; bottom: -1px; left: 0; right: 0;
      height: 1px; background: var(--amber);
      transform: scaleX(0); transition: transform 0.3s;
    }
    .menu-tab.active { color: var(--amber); }
    .menu-tab.active::after { transform: scaleX(1); }

    .menu-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 24px; margin-top: 56px;
    }
    .menu-panel { display: none; }
    .menu-panel.active { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; }

    /* 3D Tilt Card */
    .menu-card {
      background: linear-gradient(145deg, rgba(43,18,6,0.9), rgba(26,10,4,0.95));
      border: 1px solid rgba(196,122,40,0.12);
      padding: 36px 32px;
      position: relative; overflow: hidden;
      transform-style: preserve-3d;
      transition: border-color 0.3s, box-shadow 0.3s;
      will-change: transform;
    }
    .menu-card::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(circle at var(--mx,50%) var(--my,50%), rgba(196,122,40,0.08) 0%, transparent 60%);
      opacity: 0; transition: opacity 0.3s;
    }
    .menu-card:hover::before { opacity: 1; }
    .menu-card:hover { border-color: rgba(196,122,40,0.35); box-shadow: 0 20px 60px rgba(0,0,0,0.5); }

    .card-number {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.75rem; color: rgba(196,122,40,0.4);
      letter-spacing: 0.2em; margin-bottom: 20px;
    }
    .card-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.55rem; font-weight: 400; color: var(--cream);
      margin-bottom: 10px; line-height: 1.2;
    }
    .card-desc {
      font-size: 0.82rem; color: var(--smoke); line-height: 1.7;
      font-style: italic; margin-bottom: 24px;
    }
    .card-footer { display: flex; align-items: center; justify-content: space-between; }
    .card-price {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.3rem; font-weight: 600; color: var(--amber);
    }
    .card-tag {
      font-family: 'Jost', sans-serif; font-size: 0.6rem; letter-spacing: 0.25em;
      text-transform: uppercase; color: var(--smoke);
      padding: 4px 12px; border: 1px solid rgba(138,112,96,0.3);
    }

    /* ── ABOUT SECTION ── */
    #about {
      padding: 140px 0;
      background: var(--mahogany);
      position: relative; overflow: hidden;
    }
    #about::before {
      content: ''; position: absolute;
      top: -1px; left: 0; right: 0; height: 120px;
      background: linear-gradient(to bottom, var(--espresso), transparent);
    }
    #about::after {
      content: ''; position: absolute;
      bottom: -1px; left: 0; right: 0; height: 120px;
      background: linear-gradient(to top, var(--espresso), transparent);
    }
    .about-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 100px; align-items: center;
    }
    .about-image-wrap {
      position: relative; height: 600px;
      perspective: 1000px;
    }
    .about-img-main {
      width: 100%; height: 100%;
      object-fit: cover;
      border: 1px solid rgba(196,122,40,0.15);
      display: block;
      background:
        linear-gradient(135deg, rgba(122,51,24,0.5) 0%, rgba(43,18,6,0.8) 100%),
        url('https://picsum.photos/seed/coffee1/600/700') center/cover;
    }
    .about-img-accent {
      position: absolute; bottom: -40px; right: -40px;
      width: 200px; height: 200px;
      border: 1px solid rgba(196,122,40,0.25);
      background:
        linear-gradient(135deg, rgba(196,122,40,0.3) 0%, rgba(26,10,4,0.9) 100%),
        url('https://picsum.photos/seed/coffee2/200/200') center/cover;
    }
    .about-img-label {
      position: absolute; top: 30px; left: -20px;
      writing-mode: vertical-rl; text-orientation: mixed;
      font-family: 'Jost', sans-serif; font-weight: 200;
      font-size: 0.6rem; letter-spacing: 0.4em; text-transform: uppercase;
      color: var(--amber); padding: 0 10px;
    }

    .about-text .section-title { margin-bottom: 32px; }
    .about-body {
      font-size: 1rem; line-height: 1.95; color: rgba(244,234,216,0.75);
      margin-bottom: 24px;
    }
    .about-stats {
      display: grid; grid-template-columns: repeat(3,1fr);
      gap: 32px; margin-top: 56px;
      padding-top: 40px; border-top: 1px solid rgba(196,122,40,0.15);
    }
    .stat-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 3rem; font-weight: 300; color: var(--amber);
      line-height: 1;
    }
    .stat-label {
      font-family: 'Jost', sans-serif; font-weight: 200;
      font-size: 0.65rem; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--smoke); margin-top: 6px;
    }

    /* ── QUOTE BAND ── */
    .quote-band {
      padding: 80px 60px;
      background: var(--amber);
      position: relative; overflow: hidden;
    }
    .quote-band::before {
      content: '\201C'; position: absolute;
      font-family: 'Cormorant Garamond', serif;
      font-size: 30rem; font-weight: 700; line-height: 1;
      color: rgba(0,0,0,0.06);
      top: -80px; left: 40px; pointer-events: none;
    }
    .quote-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.6rem, 3.5vw, 2.8rem);
      font-style: italic; font-weight: 300;
      color: var(--espresso); max-width: 900px; margin: 0 auto;
      text-align: center; line-height: 1.5; position: relative;
    }
    .quote-author {
      font-family: 'Jost', sans-serif; font-weight: 300;
      font-size: 0.68rem; letter-spacing: 0.4em; text-transform: uppercase;
      color: rgba(20,10,4,0.55); text-align: center; margin-top: 24px;
    }

    /* ── GALLERY ── */
    #gallery {
      padding: 130px 0;
      background: var(--espresso);
    }
    .gallery-header { margin-bottom: 64px; }
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      grid-template-rows: auto;
      gap: 16px;
    }
    .g-item {
      overflow: hidden; position: relative;
      background: var(--mahogany);
    }
    .g-item::after {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(20,10,4,0.7) 0%, transparent 50%);
      opacity: 0; transition: opacity 0.4s;
    }
    .g-item:hover::after { opacity: 1; }
    .g-item img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform 0.7s cubic-bezier(.4,0,.2,1);
      display: block;
    }
    .g-item:hover img { transform: scale(1.06); }
    .g-item-label {
      position: absolute; bottom: 20px; left: 20px; z-index: 2;
      font-family: 'Cormorant Garamond', serif; font-size: 0.95rem;
      letter-spacing: 0.1em; color: var(--cream);
      opacity: 0; transform: translateY(10px);
      transition: opacity 0.4s, transform 0.4s;
    }
    .g-item:hover .g-item-label { opacity: 1; transform: translateY(0); }

    /* gallery layout */
    .g1 { grid-column: 1/6; grid-row: 1; height: 420px; }
    .g2 { grid-column: 6/9; grid-row: 1; height: 420px; }
    .g3 { grid-column: 9/13; grid-row: 1; height: 420px; }
    .g4 { grid-column: 1/4; grid-row: 2; height: 300px; }
    .g5 { grid-column: 4/9; grid-row: 2; height: 300px; }
    .g6 { grid-column: 9/13; grid-row: 2; height: 300px; }

    /* ── CONTACT SECTION ── */
    #contact {
      padding: 130px 0 80px;
      background: linear-gradient(180deg, var(--espresso) 0%, var(--mahogany) 100%);
    }
    .contact-grid {
      display: grid; grid-template-columns: 1fr 1.4fr;
      gap: 100px; align-items: start;
    }
    .contact-info .section-title { margin-bottom: 48px; }
    .contact-detail {
      margin-bottom: 36px;
    }
    .detail-label {
      font-family: 'Jost', sans-serif; font-weight: 200;
      font-size: 0.62rem; letter-spacing: 0.5em; text-transform: uppercase;
      color: var(--amber); margin-bottom: 8px;
    }
    .detail-value {
